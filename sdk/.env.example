# ===========================================================================
# AgentOps SDK configuration
# ===========================================================================

# Which LLM provider to use: mock | anthropic | bedrock
AGENTOPS_LLM_PROVIDER=mock

# --- If AGENTOPS_LLM_PROVIDER=anthropic ---
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
# Optional override:
# AGENTOPS_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- If AGENTOPS_LLM_PROVIDER=bedrock ---
# Uses your AWS credentials (boto3 default chain — no API key needed).
# AWS_REGION is read from the AWS CLI config; override if needed.
# AGENTOPS_BEDROCK_MODEL options:
#   anthropic.claude-haiku-4-5-v1:0        (default)
#   meta.llama3-8b-instruct-v1:0
#   amazon.titan-text-express-v1
# AGENTOPS_BEDROCK_MODEL=anthropic.claude-haiku-4-5-v1:0

# --- Transport configuration ---
# Leave these blank in Phase 2.1 to write events to local files.
AGENTOPS_ENDPOINT_URL=
AGENTOPS_API_KEY=
AGENTOPS_LOCAL_OUTPUT_DIR=./local_output